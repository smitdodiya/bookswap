# Copy to .env and fill in real values. Never commit the real .env.

# Postgres connection string from Neon (https://neon.tech). Must include ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change_me_to_a_long_random_string"

# Port the API listens on (Render sets this automatically in production).
PORT=4000
